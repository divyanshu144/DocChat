cument Embedding)", "file_type": "document", "source_file": "README.md", "source_location": "line 82", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Optionally embeds a hypothetical answer generated by LLM instead of the raw question to improve semantic search on vague queries. Disabled by default."}, {"id": "concept_two_layer_cache", "label": "Two-Layer Retrieval Cache (L1 LRU + L2 Redis)", "file_type": "document", "source_file": "README.md", "source_location": "line 82", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "L1 in-process LRU (cachetools maxsize=50) keeps hot documents in-process; L2 Redis shares cache across instances for horizontal scaling."}, {"id": "concept_sse_streaming", "label": "SSE Token Streaming to Browser", "file_type": "document", "source_file": "README.md", "source_location": "line 79", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_background_ingestion", "label": "Background Ingestion (BackgroundTasks or ARQ)", "file_type": "document", "source_file": "README.md", "source_location": "line 85", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Upload returns immediately; browser polls until document is ready. Uses FastAPI BackgroundTasks by default; switches to ARQ when REDIS_URL is set."}], "edges": [{"source": "readme_rag_pipeline", "target": "concept_hybrid_retrieval", "relation": "documents", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "line 32", "weight": 1.0}, {"source": "readme_rag_pipeline", "target": "concept_hyde", "relation": "documents", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "line 29", "weight": 1.0}, {"source": "readme_rag_pipeline", "target": "concept_sse_streaming", "relation": "documents", "confidence": "EXTRACTED", "confidence_score":