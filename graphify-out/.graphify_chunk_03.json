      "rationale": "BM25 sparse retrieval combined with dense cosine similarity and fused via Reciprocal Rank Fusion (k=60) to outperform either method alone on recall."
    },
    {
      "id": "concept_hyde",
      "label": "HyDE (Hypothetical Document Embedding)",
      "file_type": "document",
      "source_file": "README.md",
      "source_location": "line 82",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Optionally embeds a hypothetical answer generated by LLM instead of the raw question to improve semantic search on vague queries. Disabled by default."
    },
    {
      "id": "concept_two_layer_cache",
      "label": "Two-Layer Retrieval Cache (L1 LRU + L2 Redis)",
      "file_type": "document",
      "source_file": "README.md",
      "source_location": "line 82",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "L1 in-process LRU (cachetools maxsize=50) keeps hot documents in-process; L2 Redis shares cache across instances for horizontal scaling."
